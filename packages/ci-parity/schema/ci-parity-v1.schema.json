{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umbraculum.dev/schemas/ci-parity/v1.json",
  "title": "Umbraculum CI Parity Manifest v1",
  "type": "object",
  "required": ["schemaVersion", "profile", "runtime", "snapshot", "install", "jobs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "profile": {
      "enum": ["ts-npm-monorepo", "python", "magento-php"]
    },
    "runtime": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": { "type": "string" },
        "nodeOptions": { "type": "string" }
      }
    },
    "snapshot": {
      "type": "object",
      "required": ["local", "ci"],
      "properties": {
        "local": { "const": "git-archive" },
        "ci": { "const": "checkout" }
      }
    },
    "install": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string" },
        "nested": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "command", "afterJob", "beforeJob"],
            "properties": {
              "path": { "type": "string" },
              "command": { "type": "string" },
              "afterJob": { "type": "string" },
              "beforeJob": { "type": "string" }
            }
          }
        }
      }
    },
    "jobs": {
      "type": "array",
      "minItems": 1
    }
  }
}
